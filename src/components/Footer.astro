---
const year = new Date().getFullYear();
---

<footer class="border-t border-surface-200 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-8">
      <div>
        <div class="flex items-center gap-2 mb-3">
          <svg class="h-5 w-5 text-brand-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
          </svg>
          <span class="font-bold text-surface-900">TradGo</span>
        </div>
        <p class="text-sm text-surface-600 leading-relaxed">
          AI agents for UK trades. Catch every missed call, win more jobs.
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-surface-900 mb-3">For trades</h3>
        <ul class="space-y-2 text-sm text-surface-600">
          <li><a href="/electricians" class="hover:text-surface-900 transition-colors">Electricians</a></li>
          <li><a href="/plumbers" class="hover:text-surface-900 transition-colors">Plumbers</a></li>
          <li><a href="/roofers" class="hover:text-surface-900 transition-colors">Roofers</a></li>
          <li><a href="/gas-engineers" class="hover:text-surface-900 transition-colors">Gas Engineers</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-surface-900 mb-3">Resources</h3>
        <ul class="space-y-2 text-sm text-surface-600">
          <li><a href="/guides" class="hover:text-surface-900 transition-colors">Guides</a></li>
          <li><a href="/dashboard" class="hover:text-surface-900 transition-colors">Sign in</a></li>
          <li><a href="/dashboard" class="hover:text-surface-900 transition-colors">Start free trial</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-surface-900 mb-3">Legal</h3>
        <ul class="space-y-2 text-sm text-surface-600">
          <li><a href="/privacy" class="hover:text-surface-900 transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-surface-900 transition-colors">Terms of Service</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-6 border-t border-surface-100 text-center">
      <p class="text-xs text-surface-400">
        © {year} TradGo. Built for UK trades. All rights reserved. Operated by Autaimate Ltd.
      </p>
    </div>
  </div>
</footer>
