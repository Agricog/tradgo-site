---
import PhoneMockup from '@/components/PhoneMockup.astro';

export interface Props {
  title: string;
  subtitle: string;
  voiceQuestion: string;
  conversation: Array<{
    from: 'agent' | 'customer';
    text: string;
    time: string;
  }>;
}

const { title, subtitle, voiceQuestion, conversation } = Astro.props;
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-brand-50 via-white to-emerald-50"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-16 sm:pt-24 sm:pb-24">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-surface-900 tracking-tight leading-[1.1]">
          {title}
        </h1>

        <p class="mt-6 text-lg sm:text-xl text-surface-700 leading-relaxed max-w-2xl">
          {subtitle}
        </p>

        <p id="quick-answer" class="sr-only">{voiceQuestion}</p>

        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <a
            href="https://app.tradgo.co.uk/dashboard"
            class="inline-flex items-center justify-center gap-2 bg-brand-600 hover:bg-brand-700 text-white font-semibold px-6 py-3.5 rounded-xl text-base transition-colors shadow-sm"
          >
            Start your 14-day free trial
            <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
          <a
            href="#how-it-works"
            class="inline-flex items-center justify-center gap-2 bg-white hover:bg-surface-50 text-surface-700 font-medium px-6 py-3.5 rounded-xl text-base transition-colors border border-surface-200"
          >
            See how it works
          </a>
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-surface-700">
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4 text-brand-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            14-day free trial
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4 text-brand-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            Keep your existing number
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4 text-brand-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            Live in 10 minutes
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4 text-brand-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            Cancel anytime
          </span>
        </div>
      </div>

      <div class="hidden lg:flex justify-center">
        <PhoneMockup conversation={conversation} />
      </div>
    </div>
  </div>
</section>
