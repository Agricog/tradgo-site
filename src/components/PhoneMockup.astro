---
export interface Props {
  conversation: Array<{
    from: 'agent' | 'customer';
    text: string;
    time: string;
  }>;
}

const { conversation } = Astro.props;
---

<div class="relative mx-auto w-[280px] sm:w-[320px]">
  <div class="rounded-[2.5rem] border-[8px] border-surface-800 bg-surface-900 p-1 shadow-2xl">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-6 bg-surface-800 rounded-b-2xl z-10"></div>

    <div class="rounded-[2rem] bg-white overflow-hidden pt-8">
      <div class="px-5 pb-2 flex items-center justify-between text-[10px] text-surface-700">
        <span>14:21</span>
        <span>5G</span>
      </div>

      <div class="mx-3 mb-3 bg-red-50 border border-red-200 rounded-xl px-3 py-2.5">
        <div class="flex items-center gap-2">
          <div class="h-6 w-6 rounded-full bg-red-100 flex items-center justify-center">
            <svg class="h-3 w-3 text-red-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M10.68 13.31a16 16 0 0 0 3.41 2.6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7 2 2 0 0 1 1.72 2v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91"></path>
              <line x1="22" y1="2" x2="2" y2="22"></line>
            </svg>
          </div>
          <div>
            <p class="text-[11px] font-semibold text-red-700">Missed call</p>
            <p class="text-[10px] text-red-500">07985 559 775 · just now</p>
          </div>
        </div>
      </div>

      <div class="px-3 space-y-2.5 pb-4">
        {conversation.map((msg) => (
          msg.from === 'agent' ? (
            <div class="flex justify-start">
              <div class="bg-brand-600 text-white rounded-2xl rounded-tl-md px-3.5 py-2.5 max-w-[85%] shadow-sm">
                <p class="text-[11px] leading-relaxed">{msg.text}</p>
                <p class="text-[9px] text-brand-100 mt-1">{msg.time}</p>
              </div>
            </div>
          ) : (
            <div class="flex justify-end">
              <div class="bg-surface-100 text-surface-800 rounded-2xl rounded-tr-md px-3.5 py-2.5 max-w-[85%]">
                <p class="text-[11px] leading-relaxed">{msg.text}</p>
                <p class="text-[9px] text-surface-700 mt-1 text-right">{msg.time}</p>
              </div>
            </div>
          )
        ))}

        <div class="flex justify-end">
          <div class="bg-surface-100 rounded-2xl px-4 py-3">
            <div class="flex gap-1">
              <div class="h-1.5 w-1.5 rounded-full bg-surface-700 animate-bounce" style="animation-delay: 0ms;"></div>
              <div class="h-1.5 w-1.5 rounded-full bg-surface-700 animate-bounce" style="animation-delay: 150ms;"></div>
              <div class="h-1.5 w-1.5 rounded-full bg-surface-700 animate-bounce" style="animation-delay: 300ms;"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
